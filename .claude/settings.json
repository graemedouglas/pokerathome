{
  "env": {
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(npx jest:*)",
      "Bash(npx vitest run:*)",
      "Bash(pnpm --filter e2e test)",
      "Bash(pnpm --filter e2e test:unit:*)",
      "Bash(pnpm --filter @pokerathome/ui exec tsc:*)",
      "Bash(pnpm --filter @pokerathome/server exec tsc:*)",
      "Bash(NODE_OPTIONS=\"--max-old-space-size=4096\" npx jest:*)",
      "Bash(pnpm --filter e2e exec jest:*)",
      "Bash(NODE_OPTIONS=\"--max-old-space-size=8192\" pnpm --filter e2e test:unit:*)",
      "Bash(pnpm:*)",
      "Bash(wc -l:*)",
      "Bash(find:*)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(json.dumps\\({k: \\(v if k != ''events'' else f''[{len\\(v\\)} events]''\\) for k,v in d.items\\(\\)}, indent=2\\)\\)\")",
      "Bash(python3:*)",
      "Bash(netstat -ano)",
      "Bash(tasklist //FI \"PID eq 33340\")"
    ],
    "additionalDirectories": [
      "\\tmp"
    ]
  },
  "autoUpdatesChannel": "latest"
}
